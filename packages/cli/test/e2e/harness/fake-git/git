#!/usr/bin/env node

// Test-only fake `git` for hermetic, offline e2e coverage of wtw's
// git-dependent paths (real-vs-simulated: this is SIMULATED Git). A case selects
// it by pointing an executable-resolution env var at this file via the
// `__FAKE_GIT_BIN__` sentinel the runner rewrites to this file's absolute path.
//
// It records every invocation and injects deterministic behavior via env:
//
//   git --version                -> prints a version, exit 0 (availability probe)
//   any other invocation         -> prints FAKE_GIT_STDOUT (if set), exit 0,
//                                    unless FAKE_GIT_FAIL is set (then exit
//                                    non-zero after writing FAKE_GIT_STDERR)
//
// Wiring (all via the case's `env:` map, since the shim is checked-in harness
// infra outside the temp tree):
//   __FAKE_GIT_BIN__  sentinel the runner resolves to this script's abs path
//   FAKE_GIT_STDOUT   stdout text emitted for a non-`--version` invocation
//   FAKE_GIT_FAIL     when set (non-empty), exit non-zero after writing stderr
//   FAKE_GIT_STDERR   stderr text emitted when FAKE_GIT_FAIL is set
//   FAKE_GIT_LOG      absolute path of the invocation log (defaults to
//                     `<cwd>/.fake-git.log`)
//
// Every invocation appends one JSON line — `{ "argv": [...], "cwd": "..." }` —
// to the log so a case (or self-test) can assert the exact command wtw ran and
// the directory it ran from. This file is ESM (the package is `type: module`),
// so it uses `import`, not `require`.

import { appendFileSync } from "node:fs";
import path from "node:path";

const argv = process.argv.slice(2);

function recordInvocation() {
  const logPath =
    process.env.FAKE_GIT_LOG ?? path.join(process.cwd(), ".fake-git.log");
  try {
    appendFileSync(
      logPath,
      `${JSON.stringify({ argv, cwd: process.cwd() })}\n`,
    );
  } catch {
    // Recording is best-effort; never let it mask the simulated behavior.
  }
}

function main() {
  recordInvocation();

  if (argv.includes("--version")) {
    process.stdout.write("git version 2.0.0 (fake-git)\n");
    process.exit(0);
  }

  if (process.env.FAKE_GIT_FAIL) {
    process.stderr.write(
      `${process.env.FAKE_GIT_STDERR ?? "fatal: fake-git: simulated failure"}\n`,
    );
    process.exit(1);
  }

  const stdout = process.env.FAKE_GIT_STDOUT;
  if (stdout !== undefined && stdout.length > 0) {
    process.stdout.write(stdout.endsWith("\n") ? stdout : `${stdout}\n`);
  }
  process.exit(0);
}

main();
