#!/usr/bin/env node

// Test-only fake `git` for hermetic, offline e2e coverage of wtw's
// git-dependent paths (real-vs-simulated: this is SIMULATED Git). A case selects
// it by pointing an executable-resolution env var at this file via the
// `__FAKE_GIT_BIN__` sentinel the runner rewrites to this file's absolute path.
//
// It records every invocation and injects deterministic behavior via env:
//
//   git --version                -> prints a version, exit 0 (availability probe)
//   any other invocation         -> prints FAKE_GIT_STDOUT (if set), exit 0,
//                                    unless FAKE_GIT_FAIL is set (then exit
//                                    non-zero after writing FAKE_GIT_STDERR)
//
// Wiring (all via the case's `env:` map, since the shim is checked-in harness
// infra outside the temp tree):
//   __FAKE_GIT_BIN__  sentinel the runner resolves to this script's abs path
//   FAKE_GIT_STDOUT   stdout text emitted for a non-`--version` invocation
//   FAKE_GIT_FAIL     when set (non-empty), exit non-zero after writing stderr
//   FAKE_GIT_STDERR   stderr text emitted when FAKE_GIT_FAIL is set
//   FAKE_GIT_LOG      absolute path of the invocation log (defaults to
//                     `<cwd>/.fake-git.log`)
//
// Every invocation appends one JSON line — `{ "argv": [...], "cwd": "..." }` —
// to the log so a case (or self-test) can assert the exact command wtw ran and
// the directory it ran from. This file is ESM (the package is `type: module`),
// so it uses `import`, not `require`.

import { appendFileSync } from "node:fs";
import path from "node:path";

const argv = process.argv.slice(2);

function recordInvocation() {
  const logPath =
    process.env.FAKE_GIT_LOG ?? path.join(process.cwd(), ".fake-git.log");
  try {
    appendFileSync(
      logPath,
      `${JSON.stringify({ argv, cwd: process.cwd() })}\n`,
    );
  } catch {
    // Recording is best-effort; never let it mask the simulated behavior.
  }
}

function out(value) {
  const text = String(value);
  process.stdout.write(text.endsWith("\n") ? text : `${text}\n`);
  process.exit(0);
}

// Repository-SHAPE simulation, opt-in via FAKE_GIT_SHAPE (so the default,
// single-stdout behavior stays byte-identical for every existing case and the
// harness self-tests). In shape mode the fake derives every path from its OWN
// cwd — so a case never has to hard-code a machine-dependent absolute path — and
// toggles a single predicate via a boolean env, letting the FR-03 cases fail
// each primary-support conjunct (and a post-discovery permission failure)
// deterministically:
//   FAKE_GIT_BARE       -> `rev-parse --is-bare-repository` reports "true"
//   FAKE_GIT_PRUNABLE   -> the primary worktree record carries a `prunable` line
//   FAKE_GIT_NO_PRIMARY -> `worktree list --porcelain` reports only a bare entry
//   FAKE_GIT_TOPLEVEL_SUFFIX -> `--show-toplevel` returns <cwd>/<suffix>
//                               (a root that does not resolve to the primary)
//   FAKE_GIT_FAIL_ON    -> comma list of argv tokens that make the fake exit 128
//                          after writing FAKE_GIT_STDERR (post-discovery failure)
function shapeMain() {
  const cwd = process.cwd();
  const failOn = (process.env.FAKE_GIT_FAIL_ON ?? "")
    .split(",")
    .map((token) => token.trim())
    .filter((token) => token.length > 0);
  if (failOn.some((token) => argv.includes(token))) {
    process.stderr.write(
      `${process.env.FAKE_GIT_STDERR ?? "fatal: fake-git: simulated post-discovery failure"}\n`,
    );
    process.exit(128);
  }

  if (argv[0] === "rev-parse") {
    if (argv.includes("--git-common-dir")) out(path.join(cwd, ".git"));
    if (argv.includes("--is-bare-repository")) {
      out(process.env.FAKE_GIT_BARE ? "true" : "false");
    }
    if (argv.includes("--show-toplevel")) {
      const suffix = process.env.FAKE_GIT_TOPLEVEL_SUFFIX;
      out(suffix ? path.join(cwd, suffix) : cwd);
    }
    process.stderr.write(`fatal: fake-git: unknown rev-parse ${argv.join(" ")}\n`);
    process.exit(128);
  }

  if (argv[0] === "worktree" && argv[1] === "list") {
    if (process.env.FAKE_GIT_NO_PRIMARY) {
      out(`worktree ${path.join(cwd, ".bare")}\nbare\n`);
    }
    const lines = [
      `worktree ${cwd}`,
      "HEAD 1111111111111111111111111111111111111111",
      "branch refs/heads/main",
    ];
    if (process.env.FAKE_GIT_PRUNABLE) {
      lines.push("prunable gitdir file points to a non-existent location");
    }
    out(`${lines.join("\n")}\n`);
  }

  if (argv[0] === "ls-files") out("");

  process.exit(0);
}

function main() {
  recordInvocation();

  if (argv.includes("--version")) {
    process.stdout.write("git version 2.0.0 (fake-git)\n");
    process.exit(0);
  }

  if (process.env.FAKE_GIT_FAIL) {
    process.stderr.write(
      `${process.env.FAKE_GIT_STDERR ?? "fatal: fake-git: simulated failure"}\n`,
    );
    process.exit(1);
  }

  if (process.env.FAKE_GIT_SHAPE) {
    shapeMain();
    return;
  }

  const stdout = process.env.FAKE_GIT_STDOUT;
  if (stdout !== undefined && stdout.length > 0) {
    process.stdout.write(stdout.endsWith("\n") ? stdout : `${stdout}\n`);
  }
  process.exit(0);
}

main();
