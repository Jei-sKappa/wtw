{
  "name": "wtw-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:cli",
    "build:cli": "cd packages/cli && bun run build",
    "check": "biome check .",
    "docs:living": "tsx packages/cli/scripts/generate-living-docs.ts",
    "docs:living:check": "tsx packages/cli/scripts/generate-living-docs.ts --check",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "vitest run packages/cli/test/e2e",
    "test:contract": "bun run build && WTW_CONTRACT=1 vitest run packages/cli/test/e2e/contract.test.ts",
    "test-and-report": "bun run check && bun run typecheck && bun run test && bun run test:e2e && bun run test:contract && bun run docs:living:check && bun run build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "@types/proper-lockfile": "^4",
    "execa": "^9.6.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  }
}
